# 依赖
node_modules/

# 构建产物（GitHub Actions 会重新 build，不用提交）
dist/

# Astro 缓存
.astro/

# 环境变量 / 密钥（切勿提交）
.env
.env.*
!.env.example

# 日志
*.log
npm-debug.log*

# 操作系统
.DS_Store
Thumbs.db
Desktop.ini
desktop.ini

# Obsidian 个人配置（窗口布局、插件缓存等，换电脑需重新配置）
.obsidian/

# Obsidian 回收站
.trash/

# 本地 IDE 设置（可选）
.vscode/
.idea/
