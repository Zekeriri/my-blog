---
import BaseLayout from './BaseLayout.astro';
import PostMeta from '../components/PostMeta.astro';

const { title, pubDate, updatedDate, category, tags } = Astro.props;
---

<BaseLayout title={title}>
  <article class="card prose">
    <h1>{title}</h1>
    <PostMeta pubDate={pubDate} updatedDate={updatedDate} category={category} />
    {tags.length > 0 && (
      <div class="tags" style="margin-bottom: 1.5rem;">
        {tags.map((tag: string) => (
          <a class="tag" href={`${import.meta.env.BASE_URL}tags/${encodeURIComponent(tag)}/`}>
            {tag}
          </a>
        ))}
      </div>
    )}
    <slot />
  </article>
</BaseLayout>
