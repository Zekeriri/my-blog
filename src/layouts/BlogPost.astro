---
import BaseLayout from './BaseLayout.astro';

const { title, pubDate, category, tags } = Astro.props;
---

<BaseLayout title={title}>
  <article class="card prose">
    <h1>{title}</h1>
    <div class="meta">
      <time datetime={pubDate.toISOString()}>
        {pubDate.toLocaleDateString('zh-CN')}
      </time>
      {' · '}
      <a class="category" href={`${import.meta.env.BASE_URL}categories/${encodeURIComponent(category)}/`}>
        {category}
      </a>
    </div>
    {tags.length > 0 && (
      <div class="tags" style="margin-bottom: 1.5rem;">
        {tags.map((tag: string) => (
          <a class="tag" href={`${import.meta.env.BASE_URL}tags/${encodeURIComponent(tag)}/`}>
            {tag}
          </a>
        ))}
      </div>
    )}
    <slot />
  </article>
</BaseLayout>
