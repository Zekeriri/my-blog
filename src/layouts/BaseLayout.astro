---
import '../styles/global.css';

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description ?? '个人博客'} />
    <title>{title ? `${title} | 我的博客` : '我的博客'}</title>
  </head>
  <body>
    <header class="site-header">
      <nav>
        <a class="site-title" href={import.meta.env.BASE_URL}>我的博客</a>
        <a href={import.meta.env.BASE_URL}>首页</a>
        <a href={`${import.meta.env.BASE_URL}categories/`}>分类</a>
        <a href={`${import.meta.env.BASE_URL}tags/`}>标签</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>不疑, 不惧, 去求知, 知晓一切, 方得救赎</p>
    </footer>
  </body>
</html>
