---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostMeta from '../components/PostMeta.astro';
import { getPostTitle, getSortDate, getUpdatedDate } from '../utils/post';

const posts = (await getCollection('blog')).sort(
  (a, b) => getSortDate(b).valueOf() - getSortDate(a).valueOf()
);
---

<BaseLayout title="首页" description="算法题、八股与学习笔记">
  <h1>最新文章</h1>
  <p class="meta">用 Markdown 记录学习内容，按分类和标签整理。</p>

  {posts.map((post) => (
    <article class="card">
      <h2>
        <a href={`${import.meta.env.BASE_URL}blog/${post.id}/`}>{getPostTitle(post)}</a>
      </h2>
      <PostMeta
        pubDate={post.data.pubDate}
        updatedDate={getUpdatedDate(post)}
        category={post.data.category}
      />
      {post.data.tags.length > 0 && (
        <div class="tags">
          {post.data.tags.map((tag) => (
            <a class="tag" href={`${import.meta.env.BASE_URL}tags/${encodeURIComponent(tag)}/`}>
              {tag}
            </a>
          ))}
        </div>
      )}
    </article>
  ))}
</BaseLayout>
