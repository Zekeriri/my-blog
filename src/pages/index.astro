---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPostTitle } from '../utils/post';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="首页" description="算法题、八股与学习笔记">
  <h1>最新文章</h1>
  <p class="meta">用 Markdown 记录学习内容，按分类和标签整理。</p>

  {posts.map((post) => (
    <article class="card">
      <h2>
        <a href={`${import.meta.env.BASE_URL}blog/${post.id}/`}>{getPostTitle(post)}</a>
      </h2>
      <div class="meta">
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('zh-CN')}
        </time>
        {' · '}
        <a
          class="category"
          href={`${import.meta.env.BASE_URL}categories/${encodeURIComponent(post.data.category)}/`}
        >
          {post.data.category}
        </a>
      </div>
      {post.data.tags.length > 0 && (
        <div class="tags">
          {post.data.tags.map((tag) => (
            <a class="tag" href={`${import.meta.env.BASE_URL}tags/${encodeURIComponent(tag)}/`}>
              {tag}
            </a>
          ))}
        </div>
      )}
    </article>
  ))}
</BaseLayout>
